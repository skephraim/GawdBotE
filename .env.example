# ── LLM providers (tried in order — first working one wins) ───────────────────
# Options: nvidia,openrouter,ollama,openai,anthropic (openrouter = cloud backup, covers 200+ models)
LLM_PROVIDERS=nvidia,openrouter,ollama

# NVIDIA NIM (free tier at build.nvidia.com)
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_VISION_MODEL=meta/llama-3.2-11b-vision-instruct

# Ollama (local, fully offline)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.3
OLLAMA_VISION_MODEL=llava

# OpenAI (optional fallback)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic (optional fallback)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6

# OpenRouter (optional, access many models via one key)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# ── Interfaces ────────────────────────────────────────────────────────────────
# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_USER_ID=123456789    # your Telegram user ID (0 = allow all)

# Discord (set DISCORD_ENABLED=true to enable)
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_ID=0          # 0 = respond in any channel

# Slack (set SLACK_ENABLED=true to enable; needs Socket Mode app)
SLACK_ENABLED=false
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Webhook server
WEBHOOK_ENABLED=true
WEBHOOK_PORT=8080
WEBHOOK_SECRET=changeme        # set a strong secret!

# ── PC control ────────────────────────────────────────────────────────────────
PC_CONTROL_ENABLED=true        # set false to disable mouse/keyboard access

# ── Voice ─────────────────────────────────────────────────────────────────────
VOICE_ENABLED=true
WAKE_WORD=hey jarvis
WHISPER_MODEL=base             # tiny / base / small / medium / large
WHISPER_DEVICE=cuda            # cuda or cpu
# PIPER_MODEL=/home/you/.local/share/piper/en_GB-northern_english_male-medium.onnx

# ── Web search ────────────────────────────────────────────────────────────────
WEB_SEARCH_PROVIDER=duckduckgo  # duckduckgo (free) or brave
# BRAVE_API_KEY=your-brave-key    # required only if WEB_SEARCH_PROVIDER=brave
WEB_SEARCH_MAX_RESULTS=5

# ── Self-evolution (GitHub PR creation) ───────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_REPO=yourusername/superai
SELF_EVOLVE_AUTO_MERGE=false   # true = dangerous! auto-merges to main

# ── Cron scheduler ────────────────────────────────────────────────────────────
CRON_ENABLED=true
# JSON array of scheduled jobs:
CRON_JOBS=[{"schedule":"0 9 * * *","message":"Good morning! Summarize my day."}]
